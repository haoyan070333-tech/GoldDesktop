<Window x:Class="GoldDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="黄金走势监测与预测"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <!-- 两列布局：左侧为文字信息与预测，右侧整列为折线图（左/右比例 2:3） -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部信息：时间 + 单位开关 + 美元价 + 人民币价 -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="当前时间：" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock x:Name="TxtTime" Margin="5,0" FontSize="14"/>
            </StackPanel>

            <!-- 单位选择：图表与预测按所选单位显示 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="显示单位：" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                <RadioButton x:Name="RbUsd" Content="美元/盎司" GroupName="Unit" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" Checked="Unit_Checked"/>
                <RadioButton x:Name="RbCny" Content="人民币/克" GroupName="Unit" VerticalAlignment="Center" Checked="Unit_Checked"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                <TextBlock Text="美元计价 (美元/盎司)：" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock x:Name="TxtPriceUsd" Margin="5,0" FontSize="16" FontWeight="Bold" Foreground="DarkGoldenrod"/>
                <TextBlock x:Name="TxtChangeUsd" Margin="15,0,0,0" FontSize="12" Foreground="Gray"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="人民币计价 (元/克)：" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock x:Name="TxtPriceCny" Margin="5,0" FontSize="16" FontWeight="Bold" Foreground="DarkGreen"/>
                <TextBlock x:Name="TxtChangeCny" Margin="15,0,0,0" FontSize="12" Foreground="Gray"/>
            </StackPanel>

            <!-- 价格提醒：低于/高于指定值时播放提示音并弹窗，关闭弹窗后消除本次提醒 -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="价格提醒（与当前显示单位一致）：" VerticalAlignment="Center" FontSize="13" Margin="0,0,8,0"/>
                <TextBlock Text="低于" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtAlertBelow" Width="72" VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="留空不提醒"/>
                <TextBlock Text="提醒" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="高于" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtAlertAbove" Width="72" VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="留空不提醒"/>
                <TextBlock Text="提醒" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <CheckBox x:Name="ChkLockXAxis"
                          Content="锁定横坐标"
                          VerticalAlignment="Center"
                          Checked="LockXAxis_Checked"
                          Unchecked="LockXAxis_Checked"/>
            </StackPanel>
        </StackPanel>

        <!-- 状态信息 -->
        <TextBlock x:Name="TxtStatus" Grid.Row="1" Grid.Column="0" Foreground="Gray" Margin="0,0,0,10"/>

        <!-- 预测结果：每 2 分钟更新均线/上线/下线（左列） -->
        <GroupBox Header="未来 30 分钟走势预测（每 2 分钟更新，均线/上线/下线，仅供参考）"
                  Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
            <ListBox x:Name="LstForecast" />
        </GroupBox>

        <!-- 右侧整列显示折线统计图（单位随开关变化） -->
        <GroupBox x:Name="GrpKline" Header="价格折线图（最近 1 小时）"
                  Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Margin="0,0,0,0">
            <oxy:PlotView x:Name="KlinePlot"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />
        </GroupBox>
    </Grid>
</Window>

